{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@crp/shared": ["../../packages/shared/src"],
      "@crp/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "vite-env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
