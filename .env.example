# ─── Server ───
NODE_ENV=development
PORT=4000

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/car_rental?schema=public

# ─── JWT ───
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long

# ─── CORS ───
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Twilio (SMS OTP) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Cloud Storage (S3) ───
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Cloud Storage (Cloudinary - alternative) ───
CLOUDINARY_URL=

# ─── Payment (Stripe) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Firebase (Push Notifications) ───
FIREBASE_SERVICE_ACCOUNT=

# ─── Email (SMTP) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@carrental.com

# ─── App URLs ───
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
